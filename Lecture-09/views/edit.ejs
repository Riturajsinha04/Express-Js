<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Poppins", Arial, sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a, #1e3a8a, #7c3aed);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .form-box {
            width: 400px;
            padding: 35px;
            border-radius: 22px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.35);
            color: white;
        }

        .form-box h1 {
            text-align: center;
            margin-bottom: 8px;
            font-size: 32px;
            letter-spacing: 1px;
        }

        .form-box p {
            text-align: center;
            color: #dbeafe;
            margin-bottom: 28px;
            font-size: 15px;
        }

        .input-group {
            margin-bottom: 18px;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #dbeafe;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 13px 15px;
            border: none;
            outline: none;
            border-radius: 12px;
            font-size: 15px;
            color: white;
            background: rgba(255, 255, 255, 0.16);
            border: 1px solid rgba(255, 255, 255, 0.25);
        }

        input::placeholder {
            color: #cbd5e1;
        }

        input:focus {
            border-color: #38bdf8;
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.25);
        }

        button {
            width: 100%;
            padding: 14px;
            margin-top: 10px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #22c55e, #38bdf8);
            color: white;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s ease;
        }

        button:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(34, 197, 94, 0.35);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 18px;
            color: #dbeafe;
            text-decoration: none;
            font-size: 14px;
        }

        .back-link:hover {
            color: #38bdf8;
        }
    </style>
</head>
<body>

    <div class="form-box">
        <h1>Edit Student</h1>
        <p>Update student details below</p>

        <form action="/update/<%= data._id %>" method="POST">

            <div class="input-group">
                <label>Name</label>
                <input type="text" name="name" placeholder="Enter Name" value="<%= data.name %>">
            </div>

            <div class="input-group">
                <label>Age</label>
                <input type="number" name="age" placeholder="Enter Age" value="<%= data.age %>">
            </div>

            <div class="input-group">
                <label>Course</label>
                <input type="text" name="course" placeholder="Enter Course" value="<%= data.course %>">
            </div>

            <div class="input-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="Enter Email" value="<%= data.email %>">
            </div>

            <button type="submit">Update Student</button>

        </form>

        <a href="/getdata" class="back-link">← Back to Students</a>
    </div>

</body>
</html>