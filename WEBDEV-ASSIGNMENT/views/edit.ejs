<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Mobile</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }

        h1 {
            color: white;
            margin-bottom: 25px;
            font-size: 35px;
            letter-spacing: 1px;
        }

        form {
            width: 400px;
            background-color: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4);
        }

        input {
            width: 100%;
            padding: 12px;
            margin-bottom: 18px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 15px;
            outline: none;
        }

        input:focus {
            border-color: #2c5364;
            box-shadow: 0 0 6px rgba(44, 83, 100, 0.5);
        }

        button {
            width: 100%;
            padding: 12px;
            background-color: #203a43;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 17px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background-color: #0f2027;
        }

        a {
            margin-top: 20px;
            color: white;
            text-decoration: none;
            background-color: black;
            padding: 10px 20px;
            border-radius: 8px;
            transition: 0.3s;
        }

        a:hover {
            background-color: #333;
        }
    </style>
</head>
<body>

    <h1>Edit Mobile</h1>

    <form action="/update/<%= data._id %>" method="POST">

        <input type="text" name="brand" placeholder="Enter Brand" value="<%= data.brand %>" required>

        <input type="text" name="model" placeholder="Enter Model" value="<%= data.model %>" required>

        <input type="text" name="ram" placeholder="Enter RAM" value="<%= data.ram %>" required>

        <input type="text" name="storage" placeholder="Enter Storage" value="<%= data.storage %>" required>

        <input type="number" name="price" placeholder="Enter Price" value="<%= data.price %>" required>

        <button type="submit">Edit Mobile</button>

    </form>

    <a href="/getdata">Back to Mobile Data</a>

</body>
</html>